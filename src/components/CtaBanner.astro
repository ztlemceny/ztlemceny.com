---
import { useTranslations, getLocalizedPath, type Lang } from '../utils/i18n';
import { SITE } from '../config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-terracotta py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
      {t.home.cta_title}
    </h2>
    <p class="text-white/80 text-lg mb-8 leading-relaxed">
      {t.home.cta_text}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={getLocalizedPath('/tours', lang)}
        class="inline-block px-10 py-4 bg-white text-terracotta font-bold rounded-lg text-base hover:bg-sand-50 transition-colors shadow-lg"
      >
        {t.home.cta_button}
      </a>
      <a
        href={getLocalizedPath('/custom-itinerary', lang)}
        class="inline-block px-10 py-4 border-2 border-white text-white font-bold rounded-lg text-base hover:bg-white hover:text-terracotta transition-colors shadow-lg"
      >
        {t.nav.custom_itinerary}
      </a>
    </div>
  </div>
</section>
