---
import { useTranslations, switchLangPath, getLocalizedPath, LANGS, type Lang } from '../utils/i18n';
import { SITE } from '../config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const path = Astro.url.pathname;
const isRTL = lang === 'ar';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const links = [
  { href: getLocalizedPath('/', lang), label: t.nav.home },
  { href: getLocalizedPath('/tours', lang), label: t.nav.tours },
  { href: getLocalizedPath('/about', lang), label: t.nav.about },
  { href: getLocalizedPath('/blog', lang), label: t.nav.blog },
  { href: getLocalizedPath('/gallery', lang), label: t.nav.gallery },
  { href: getLocalizedPath('/testimonials', lang), label: t.nav.testimonials },
  { href: getLocalizedPath('/custom-itinerary', lang), label: t.nav.custom_itinerary },
  { href: getLocalizedPath('/contact', lang), label: t.nav.contact },
];

const otherLangs = LANGS.filter(l => l !== lang);
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-stone-100 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={getLocalizedPath('/', lang)} class="font-heading text-xl font-bold text-stone-900 tracking-tight hover:text-terracotta transition-colors">
        Ztlemceny
      </a>

      <!-- Desktop links -->
      <div class="hidden lg:flex items-center gap-1">
        {links.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              path === link.href || (link.href !== getLocalizedPath('/', lang) && path.startsWith(link.href))
                ? 'text-terracotta bg-terracotta-50'
                : 'text-stone-600 hover:text-terracotta hover:bg-stone-50'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Lang switcher + CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <div class={`flex items-center gap-0.5 ${isRTL ? 'flex-row-reverse' : ''}`}>
          {otherLangs.map(l => (
            <a
              href={switchLangPath(path, lang, l)}
              class="px-2 py-1 text-xs font-semibold text-stone-400 hover:text-terracotta uppercase tracking-wider transition-colors"
            >
              {l}
            </a>
          ))}
        </div>
        <a
          href={getLocalizedPath('/tours', lang)}
          class="btn-primary text-sm"
        >
          {t.nav.reserve}
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        class="lg:hidden p-2 rounded-md text-stone-600 hover:text-terracotta hover:bg-stone-50 transition-colors"
        aria-label="Toggle menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div 
      id="mobile-menu" 
      class="hidden lg:hidden py-6 border-t border-stone-100 overflow-hidden transition-all duration-500 ease-in-out max-h-0"
    >
      <div class="flex flex-col gap-2 mb-6">
        {links.map(link => (
          <a
            href={link.href}
            class={`px-4 py-3 rounded-xl text-base font-medium transition-all ${
              path === link.href || (link.href !== getLocalizedPath('/', lang) && path.startsWith(link.href))
                ? 'text-terracotta bg-terracotta-50/50'
                : 'text-stone-700 hover:text-terracotta hover:bg-stone-50'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="flex flex-col gap-6 pt-6 border-t border-stone-100">
        <div class="flex gap-3 px-4">
          {otherLangs.map(l => (
            <a
              href={switchLangPath(path, lang, l)}
              class="flex-1 text-center py-2.5 text-xs font-bold text-stone-500 hover:text-terracotta border border-stone-200 rounded-xl uppercase tracking-widest transition-all hover:border-terracotta hover:bg-terracotta/5"
            >
              {l}
            </a>
          ))}
        </div>
        <div class="px-4">
          <a href={getLocalizedPath('/tours', lang)} class="btn-primary w-full text-center py-4 text-base shadow-lg shadow-terracotta/20">
            {t.nav.reserve}
          </a>
        </div>
      </div>
    </div>

  </nav>
</header>

<script>
  function initNav() {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      
      if (isHidden) {
        menu.classList.remove('hidden');
        // Small delay to allow CSS transitions to trigger
        requestAnimationFrame(() => {
          menu.style.maxHeight = '100vh';
          iconOpen?.classList.add('hidden');
          iconClose?.classList.remove('hidden');
        });
      } else {
        menu.style.maxHeight = '0';
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        setTimeout(() => {
          menu.classList.add('hidden');
        }, 500);
      }
    });
  }

  // Run on load
  initNav();
  // Support for transitions if enabled
  document.addEventListener('astro:page-load', initNav);
</script>
