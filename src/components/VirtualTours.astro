---
import { useTranslations, getLocalizedPath, type Lang } from '../utils/i18n';
import { SITE } from '../config';

interface Props {
  lang: Lang;
  hideHeader?: boolean;
}

const { lang, hideHeader = false } = Astro.props;
const t = useTranslations(lang);
const isRTL = lang === 'ar';

const vt = t.virtual_tours;

const whatsappMessage = encodeURIComponent(vt.whatsapp_message);
const whatsappUrl = `${SITE.whatsappUrl}?text=${whatsappMessage}`;

const tours = [
  {
    id: 'vt-medina',
    icon: '🕌',
    gradient: 'from-amber-600 to-orange-700',
    glow: 'shadow-amber-500/30',
  },
  {
    id: 'vt-mansourah',
    icon: '🏛️',
    gradient: 'from-stone-600 to-stone-800',
    glow: 'shadow-stone-500/30',
  },
  {
    id: 'vt-sidi',
    icon: '✨',
    gradient: 'from-emerald-700 to-teal-800',
    glow: 'shadow-emerald-500/30',
  },
  {
    id: 'vt-palace',
    icon: '👑',
    gradient: 'from-violet-700 to-purple-900',
    glow: 'shadow-violet-500/30',
  },
];
---

<section id="virtual-tours" class={`${hideHeader ? 'pt-0 pb-24' : 'py-24'} bg-stone-900 relative overflow-hidden ${isRTL ? 'rtl' : ''}`}>
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute top-0 left-0 w-96 h-96 bg-terracotta rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-olive rounded-full blur-[120px] translate-x-1/2 translate-y-1/2"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    {!hideHeader && (
      <div class="max-w-2xl mx-auto text-center mb-16 reveal">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-terracotta/20 border border-terracotta/40 text-terracotta text-xs font-semibold uppercase tracking-widest mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-terracotta animate-pulse"></span>
          {vt.badge}
        </span>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
          {vt.title}
        </h2>
        <p class="text-stone-400 text-lg leading-relaxed">
          {vt.subtitle}
        </p>
      </div>
    )}

    <!-- Virtual tour cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14 reveal">
      {tours.map((tour, i) => (
        <div class={`group relative rounded-2xl overflow-hidden cursor-pointer border border-white/5 hover:border-white/20 transition-all duration-500 hover:-translate-y-1 hover:shadow-2xl ${tour.glow}`}>
          <!-- Card gradient bg -->
          <div class={`absolute inset-0 bg-gradient-to-br ${tour.gradient} opacity-90 group-hover:opacity-100 transition-opacity`}></div>

          <!-- Decorative orb -->
          <div class="absolute -top-8 -right-8 w-32 h-32 rounded-full bg-white/5 group-hover:scale-150 transition-transform duration-700"></div>

          <!-- Content -->
          <div class="relative p-6 flex flex-col h-full min-h-[200px]">
            <div class="text-4xl mb-4">{tour.icon}</div>
            <h3 class="font-heading text-white font-bold text-lg leading-snug mb-2">
              {(vt as any)[`tour_${i + 1}_title`]}
            </h3>
            <p class="text-white/70 text-sm leading-relaxed flex-1">
              {(vt as any)[`tour_${i + 1}_desc`]}
            </p>
            <!-- Duration pill -->
            <div class="mt-4 flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-white/60 text-xs">{(vt as any)[`tour_${i + 1}_duration`]}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Block -->
    <div class="relative rounded-3xl overflow-hidden reveal">
      <!-- Glassmorphism panel -->
      <div class="absolute inset-0 bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl"></div>
      <div class="relative flex flex-col lg:flex-row items-center justify-between gap-8 p-8 lg:p-12">
        <!-- Left text -->
        <div class="flex-1 text-center lg:text-start">
          <p class="text-terracotta text-sm font-semibold uppercase tracking-widest mb-2">{vt.cta_eyebrow}</p>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-white mb-3">{vt.cta_title}</h3>
          <p class="text-stone-400 text-base max-w-lg">{vt.cta_text}</p>
          <!-- Feature pills -->
          <div class="flex flex-wrap gap-2 mt-5 justify-center lg:justify-start">
            {[vt.feature_1, vt.feature_2, vt.feature_3].map(f => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/10 text-white/80 text-xs font-medium border border-white/10">
                <svg class="w-3 h-3 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </span>
            ))}
          </div>
        </div>

        <!-- Right CTAs -->
        <div class="flex flex-col sm:flex-row lg:flex-col gap-3 flex-shrink-0 w-full sm:w-auto lg:w-60">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2.5 px-6 py-4 rounded-xl bg-[#25D366] hover:bg-[#20bc5a] text-white font-semibold text-sm transition-all duration-200 hover:shadow-lg hover:shadow-[#25D366]/30 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            {vt.cta_whatsapp}
          </a>
          <a
            href={getLocalizedPath('/contact', lang)}
            class="flex items-center justify-center gap-2 px-6 py-4 rounded-xl bg-white/10 hover:bg-white/15 text-white font-semibold text-sm border border-white/20 transition-all duration-200 hover:-translate-y-0.5"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            {vt.cta_contact}
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
