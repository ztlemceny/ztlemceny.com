---
import { useTranslations, type Lang } from '../utils/i18n';
import { SITE } from '../config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  tour: CollectionEntry<'tours'>;
  lang: Lang;
  compact?: boolean;
}

const { tour, lang, compact = false } = Astro.props;
const t = useTranslations(lang);
const { title, tagline, duration, difficulty, images, included, not_included, price, itinerary } = tour.data;
const mainImage = images[0] ?? '/images/shots/shot-01.jpg';

const [slug] = tour.slug.split('.');
const tourLink = `${import.meta.env.BASE_URL}/${lang}/tours/${slug}`.replace(/\/+/g, '/');

const whatsappMessage = t.tours.whatsapp_message_simple
  .replace('{title}', title);
const whatsappUrl = `${SITE.whatsappUrl}?text=${encodeURIComponent(whatsappMessage)}`;
---

<article class="card flex flex-col h-full group">
  <!-- Image -->
  <a href={tourLink} class={`relative overflow-hidden ${compact ? 'aspect-square' : 'aspect-[4/3]'} watermark block group-hover:opacity-90 transition-opacity`}>
    <img
      src={mainImage.startsWith('/') ? `${import.meta.env.BASE_URL}${mainImage}`.replace(/\/+/g, '/') : mainImage}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <!-- Difficulty badge -->
    <span class="absolute top-3 start-3 px-2.5 py-1 bg-white/90 backdrop-blur-sm text-stone-700 text-xs font-semibold rounded-full">
      {difficulty}
    </span>
  </a>

  <!-- Content -->
  <div class={`flex flex-col flex-1 ${compact ? 'pt-2 px-3 pb-3' : 'p-6'}`}>
    <h3 class={`font-heading ${compact ? 'text-base' : 'text-xl min-h-[3.5rem]'} font-bold text-stone-900 leading-tight mb-1 line-clamp-2`}>
      <a href={tourLink} class="hover:text-terracotta transition-colors">{title}</a>
    </h3>
    <p class={`text-stone-500 text-xs ${compact ? 'mb-1 line-clamp-2' : 'mb-4 italic line-clamp-3 min-h-[4.5rem]'}`}>{tagline}</p>

    <!-- Duration -->
    <div class={`flex items-center gap-2 ${compact ? 'text-[10px] mb-2' : 'text-sm mb-4'} text-stone-600`}>
      <svg class={`${compact ? 'w-3 h-3' : 'w-4 h-4'} text-terracotta flex-shrink-0`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>{t.tours.duration_label}: <strong>{duration}</strong></span>
    </div>

    {!compact && (
      <div class="grid grid-cols-2 gap-4 mb-5 text-xs">
        <!-- Included -->
        <div>
          <p class="font-semibold text-stone-700 mb-2">{t.tours.included_label}</p>
          <ul class="space-y-1">
            {included.map((item: string) => (
              <li class="flex items-start gap-1.5 text-stone-500">
                <svg class="w-3.5 h-3.5 text-olive mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Not included -->
        <div>
          <p class="font-semibold text-stone-700 mb-2">{t.tours.not_included_label}</p>
          <ul class="space-y-1">
            {not_included.map((item: string) => (
              <li class="flex items-start gap-1.5 text-stone-500">
                <svg class="w-3.5 h-3.5 text-stone-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    <!-- Price + CTA -->
    <div class={`mt-auto flex items-center justify-between ${compact ? 'pt-3' : 'pt-4'} border-t border-stone-100`}>
      <div>
        <p class="text-[10px] text-stone-400 uppercase tracking-wide">{t.tours.price_label}</p>
        <p class={`${compact ? 'text-xs' : 'text-sm'} font-semibold text-stone-700`}>{price || t.tours.price_value}</p>
      </div>
      <div class="flex items-center gap-2">
        <a
          href={tourLink}
          class="text-stone-400 hover:text-stone-600 transition-colors p-2"
          title="View Details"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class={`btn-primary ${compact ? 'text-[10px] px-3 py-2' : 'text-xs px-4 py-2.5'} whitespace-nowrap`}
        >
          {t.tours.reserve_button}
        </a>
      </div>
    </div>
  </div>
</article>
