---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, LANGS, getLocalizedPath, type Lang } from '../../utils/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang = 'en' } = Astro.params as { lang?: Lang };
const t = useTranslations(lang);
---

<BaseLayout title={t.contact.page_title} lang={lang}>
  <section class="relative py-32 overflow-hidden flex items-center justify-center min-h-[70vh]">
    <div class="absolute inset-0 watermark">
      <img src={`${import.meta.env.BASE_URL}/images/shots/shot-16.jpg`.replace(/\/+/g, '/')} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-olive-dark/90"></div>
    </div>
    
    <div class="relative max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div class="w-20 h-20 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-8 animate-bounce">
        <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
        {t.contact.form_success.split('!')[0]}!
      </h1>
      
      <p class="text-stone-300 text-lg mb-12 max-w-md mx-auto">
        {t.contact.form_success.split('!')[1] || t.contact.form_success}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={getLocalizedPath('/', lang)} class="btn-primary px-8 py-3 w-full sm:w-auto text-center">
          {t.nav.home}
        </a>
        <a href={getLocalizedPath('/tours', lang)} class="bg-white/10 hover:bg-white/20 text-white border border-white/20 px-8 py-3 rounded-full transition-all w-full sm:w-auto text-center">
          {t.nav.tours}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
