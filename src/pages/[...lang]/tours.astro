---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TourCard from '../../components/TourCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { getCollection } from 'astro:content';
import { useTranslations, LANGS, getLocalizedPath, type Lang } from '../../utils/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang = 'en' } = Astro.params as { lang?: Lang };
const t = useTranslations(lang);

const tours = await getCollection('tours', ({ data }) => data.lang === lang);
tours.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={t.tours.page_title} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 bg-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src={`${import.meta.env.BASE_URL}/images/shots/shot-17.jpg`.replace(/\/+/g, '/')} alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{t.tours.page_title}</h1>
      <p class="text-stone-300 text-lg">{t.tours.page_subtitle}</p>
    </div>
  </section>

  <!-- Tours grid -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {tours.map(tour => (
          <TourCard tour={tour} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />

</BaseLayout>
