---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath, type Lang } from '../../../utils/i18n';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => {
    const [slug] = post.slug.split('.');
    return {
      params: { 
        lang: post.data.lang === 'en' ? undefined : post.data.lang,
        slug: slug
      },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { lang = 'en' } = Astro.params as { lang?: Lang };
const t = useTranslations(lang);

const { title, excerpt, image, date, author } = post.data;
const { Content } = await post.render();

// Get other posts for recommendations
const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const otherPosts = allPosts
  .filter(item => item.id !== post.id)
  .sort(() => 0.5 - Math.random())
  .slice(0, 3);
---

<BaseLayout title={title} lang={lang} image={image} description={excerpt}>

  <!-- Hero / Header Image -->
  <section class="relative h-[60vh] min-h-[400px] overflow-hidden">
    <div class="absolute inset-0 watermark">
      <img src={image.startsWith('/') ? `${import.meta.env.BASE_URL}${image}`.replace(/\/+/g, '/') : image} alt={title} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-stone-900/50"></div>
    </div>
    <div class="relative h-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex items-end pb-16">
      <div class="w-full">
        <div class="flex items-center gap-4 mb-6">
          <span class="inline-block px-3 py-1 bg-terracotta text-white text-xs font-bold rounded-full uppercase tracking-widest">
            {date}
          </span>
          {author && <span class="text-stone-300 text-sm font-medium">By {author}</span>}
        </div>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6 drop-shadow-lg leading-tight">{title}</h1>
        <p class="text-xl text-stone-200 font-medium italic drop-shadow-md max-w-3xl">{excerpt}</p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Back to blog link -->
      <a href={getLocalizedPath('/blog', lang)} class="inline-flex items-center text-stone-500 hover:text-terracotta transition-colors mb-10 font-medium">
        <svg class="w-5 h-5 mr-2 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        Back to Blog
      </a>

      <!-- Body text -->
      <div class="prose prose-stone prose-lg max-w-none prose-headings:font-heading prose-headings:font-bold prose-h2:text-3xl prose-h2:text-stone-900 prose-a:text-terracotta prose-a:no-underline hover:prose-a:underline prose-img:rounded-2xl">
        <Content />
      </div>

    </div>
  </section>

  <!-- Other Posts -->
  {otherPosts.length > 0 && (
    <section class="py-20 bg-sand-50 border-t border-sand-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-bold text-stone-900 mb-10 text-center">More Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {otherPosts.map((item) => {
             const [s] = item.slug.split('.');
             const link = getLocalizedPath(`/blog/${s}`, lang);
             const imgSrc = item.data.image.startsWith('/') ? `${import.meta.env.BASE_URL}${item.data.image}`.replace(/\/+/g, '/') : item.data.image;
             return (
              <a href={link} class="group bg-white rounded-3xl overflow-hidden shadow-sm border border-stone-100 hover:shadow-md transition-all">
                <div class="aspect-video watermark overflow-hidden">
                  <img src={imgSrc} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-6">
                  <p class="text-xs text-stone-400 font-bold tracking-widest uppercase mb-2">{item.data.date}</p>
                  <h3 class="font-bold text-stone-900 group-hover:text-terracotta transition-colors line-clamp-2">{item.data.title}</h3>
                </div>
              </a>
             );
          })}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
