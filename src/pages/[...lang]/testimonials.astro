---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import PressMention from '../../components/PressMention.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { useTranslations, LANGS, getLocalizedPath, type Lang } from '../../utils/i18n';
import { SITE } from '../../config';
import testimonialData from '../../data/testimonials.json';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang = 'en' } = Astro.params as { lang?: Lang };
const t = useTranslations(lang);

const allTours = await getCollection('tours', ({ data }) => data.lang === lang);
allTours.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={t.testimonials.page_title} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 watermark">
      <img src={`${import.meta.env.BASE_URL}/images/shots/shot-06.jpg`.replace(/\/+/g, '/')} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-stone-900/70"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{t.testimonials.page_title}</h1>
      <p class="text-stone-300 text-lg">{t.testimonials.page_subtitle}</p>
    </div>
  </section>

  <!-- Press Mention -->
  <PressMention lang={lang} />

  <!-- Testimonials grid -->
  {testimonialData.length > 0 && (
    <section class="py-20 bg-sand-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {testimonialData.map(testimonial => (
            <TestimonialCard testimonial={testimonial} lang={lang} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Leave a review form -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-sand-50 rounded-2xl shadow-sm border border-stone-100 p-8 sm:p-10">
        <div class="text-center mb-8">
          <h2 class="font-heading text-3xl font-bold text-stone-900 mb-3">{t.review_form.title}</h2>
          <p class="text-stone-600">{t.review_form.subtitle}</p>
        </div>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-5"
        >
          <input type="hidden" name="access_key" value="7344dba4-900b-4548-abf7-340037d02bc6" />
          <input type="hidden" name="subject" value="New Review – Ztlemceny" />
          <input type="hidden" name="redirect" value={`https://ztlemceny.com${getLocalizedPath('/success', lang)}`} />
          <input type="checkbox" name="botcheck" style="display:none" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.review_form.form_name}</label>
              <input
                type="text"
                name="name"
                required
                class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-white"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.review_form.form_country}</label>
              <input
                type="text"
                name="country"
                required
                class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-white"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.review_form.form_tour}</label>
              <select
                name="tour"
                required
                class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-white"
              >
                {allTours.map(tour => (
                  <option value={tour.id.split('.').slice(0, -2).join('.')}>{tour.data.title}</option>
                ))}
                <option value="other">{t.review_form.tour_other}</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.review_form.form_rating}</label>
              <select
                name="rating"
                required
                class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-white"
              >
                <option value="5">{t.review_form.rating_5}</option>
                <option value="4">{t.review_form.rating_4}</option>
                <option value="3">{t.review_form.rating_3}</option>
                <option value="2">{t.review_form.rating_2}</option>
                <option value="1">{t.review_form.rating_1}</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.review_form.form_message}</label>
            <textarea
              name="review_text"
              rows="4"
              required
              class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-white resize-none"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full text-center text-sm py-3 mt-2">
            {t.review_form.form_submit}
          </button>
        </form>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />

</BaseLayout>
