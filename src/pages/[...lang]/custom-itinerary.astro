---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, LANGS, getLocalizedPath, type Lang } from '../../utils/i18n';
import { SITE } from '../../config';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang = 'en' } = Astro.params as { lang?: Lang };
const t = useTranslations(lang);

const poiGroups = [
  {
    label: t.custom_itinerary.poi_historical,
    items: [
      { id: 'palace', label: t.custom_itinerary.poi_palace },
      { id: 'mosque', label: t.custom_itinerary.poi_mosque },
      { id: 'sidi_boumediene', label: t.custom_itinerary.poi_sidi_boumediene },
      { id: 'mansourah', label: t.custom_itinerary.poi_mansourah },
      { id: 'agadir', label: t.custom_itinerary.poi_agadir },
    ]
  },
  {
    label: t.custom_itinerary.poi_nature,
    items: [
      { id: 'caves', label: t.custom_itinerary.poi_caves },
      { id: 'waterfall', label: t.custom_itinerary.poi_waterfall },
    ]
  },
  {
    label: t.custom_itinerary.poi_culture,
    items: [
      { id: 'nedroma', label: t.custom_itinerary.poi_nedroma },
      { id: 'maghnia', label: t.custom_itinerary.poi_maghnia },
      { id: 'medina', label: t.custom_itinerary.poi_medina },
      { id: 'artisan', label: t.custom_itinerary.poi_artisan },
    ]
  }
];
---

<BaseLayout title={t.custom_itinerary.page_title} lang={lang}>

  <!-- Hero Header -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 watermark">
      <img src={`${import.meta.env.BASE_URL}/images/shots/shot-17.jpg`.replace(/\/+/g, '/')} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-stone-900/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="inline-block px-3 py-1 bg-terracotta text-white text-xs font-bold rounded-full mb-4 uppercase tracking-widest">
        {t.nav.custom_itinerary}
      </span>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6 drop-shadow-lg">{t.custom_itinerary.page_title}</h1>
      <p class="text-stone-200 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">{t.custom_itinerary.page_subtitle}</p>
    </div>
  </section>

  <!-- Customization Form -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <div class="bg-white rounded-[2.5rem] p-8 md:p-12 shadow-xl shadow-stone-200/50 border border-stone-100 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-terracotta/5 rounded-full -mr-32 -mt-32 blur-3xl"></div>
        
        <form id="custom-itinerary-form" class="relative z-10 space-y-12">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Date -->
            <div class="space-y-2">
              <label for="visit-date" class="block text-sm font-bold text-stone-800 uppercase tracking-wider">{t.custom_itinerary.form_date}</label>
              <input 
                type="date" 
                id="visit-date" 
                required 
                min={new Date().toISOString().split('T')[0]} 
                class="w-full px-5 py-4 bg-stone-50 border border-stone-200 rounded-2xl focus:ring-4 focus:ring-terracotta/10 focus:border-terracotta outline-none transition-all text-stone-700" 
              />
            </div>
            
            <!-- Guests -->
            <div class="space-y-2">
              <label for="visit-guests" class="block text-sm font-bold text-stone-800 uppercase tracking-wider">{t.custom_itinerary.form_guests}</label>
              <select id="visit-guests" required class="w-full px-5 py-4 bg-stone-50 border border-stone-200 rounded-2xl focus:ring-4 focus:ring-terracotta/10 focus:border-terracotta outline-none transition-all text-stone-700 appearance-none cursor-pointer">
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
                <option value="9">9</option>
                <option value="10">10</option>
                <option value="10+">10+</option>
              </select>
            </div>
          </div>

          <!-- Places Selection -->
          <div class="space-y-6">
            <h3 class="text-sm font-bold text-stone-800 uppercase tracking-wider border-b border-stone-100 pb-2">{t.custom_itinerary.form_places}</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {poiGroups.map(group => (
                <div class="space-y-4">
                  <h4 class="text-terracotta font-bold text-sm italic">{group.label}</h4>
                  <div class="space-y-3">
                    {group.items.map(item => (
                      <label class="flex items-center gap-3 cursor-pointer group">
                        <div class="relative flex items-center justify-center">
                          <input 
                            type="checkbox" 
                            name="places" 
                            value={item.label} 
                            class="peer appearance-none w-6 h-6 border-2 border-stone-200 rounded-lg checked:bg-terracotta checked:border-terracotta transition-all" 
                          />
                          <svg class="absolute w-4 h-4 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <span class="text-stone-600 group-hover:text-stone-900 transition-colors text-sm font-medium">{item.label}</span>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Message -->
          <div class="space-y-2">
            <label for="visit-message" class="block text-sm font-bold text-stone-800 uppercase tracking-wider">{t.custom_itinerary.form_message}</label>
            <textarea 
              id="visit-message" 
              rows="4" 
              placeholder="..."
              class="w-full px-5 py-4 bg-stone-50 border border-stone-200 rounded-2xl focus:ring-4 focus:ring-terracotta/10 focus:border-terracotta outline-none transition-all text-stone-700 resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="pt-6">
            <button
              type="submit"
              class="w-full md:w-auto px-12 py-5 bg-terracotta text-white font-bold rounded-2xl shadow-xl shadow-terracotta/20 hover:bg-terracotta-dark transition-all transform hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-3"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {t.custom_itinerary.form_submit}
            </button>
          </div>
        </form>
      </div>

      <!-- FAQ / Info Section -->
      <div class="mt-20 max-w-2xl mx-auto text-center space-y-4">
        <p class="text-stone-500 italic">"Design your Tlemcen experience. Whether you're a history buff, a nature lover, or a foodie, we'll create the perfect balance for your day."</p>
        <div class="flex items-center justify-center gap-6">
           <div class="w-12 h-px bg-stone-200"></div>
           <span class="text-terracotta font-heading font-bold italic">Hamza</span>
           <div class="w-12 h-px bg-stone-200"></div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script define:vars={{ 
  whatsappUrl: SITE.whatsappUrl, 
  messageTemplate: t.custom_itinerary.whatsapp_message 
}}>
  function initCustomItinerary() {
    const form = document.getElementById('custom-itinerary-form');
    if (!form) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const date = document.getElementById('visit-date').value;
      const guests = document.getElementById('visit-guests').value;
      const message = document.getElementById('visit-message').value || 'N/A';
      
      const selectedPlaces = Array.from(document.querySelectorAll('input[name="places"]:checked'))
        .map(input => input.value);
      
      if (selectedPlaces.length === 0) {
        alert('Please select at least one place to visit.');
        return;
      }

      const placesStr = selectedPlaces.join(', ');

      const waMessage = messageTemplate
        .replace('{guests}', guests)
        .replace('{date}', date)
        .replace('{places}', placesStr)
        .replace('{message}', message);

      const url = `${whatsappUrl}?text=${encodeURIComponent(waMessage)}`;
      window.open(url, '_blank', 'noopener,noreferrer');
    });
  }

  initCustomItinerary();
  document.addEventListener('astro:page-load', initCustomItinerary);
</script>
