---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, LANGS, getLocalizedPath, type Lang } from '../../utils/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang = 'en' } = Astro.params as { lang?: Lang };
const t = useTranslations(lang);

const blogPosts = await getCollection('blog', ({ data }) => data.lang === lang);
blogPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title={t.blog?.page_title || "Blog"} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 bg-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src={`${import.meta.env.BASE_URL}/images/shots/shot-17.jpg`.replace(/\/+/g, '/')} alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{t.blog?.page_title || "Blog & History"}</h1>
      <p class="text-stone-300 text-lg">{t.blog?.page_subtitle || "Dive deeper into the stories behind Tlemcen's iconic sites."}</p>
    </div>
  </section>

  <!-- Blog grid -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {blogPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {blogPosts.map(post => {
            const slug = post.id.split('.').slice(0, -2).join('.');
            const link = getLocalizedPath(`/blog/${slug}`, lang);
            const imgSrc = post.data.image.startsWith('/') ? `${import.meta.env.BASE_URL}${post.data.image}`.replace(/\/+/g, '/') : post.data.image;
            
            return (
              <a href={link} class="group bg-white rounded-3xl overflow-hidden shadow-sm border border-stone-100 hover:shadow-md transition-all flex flex-col">
                <div class="aspect-[4/3] watermark overflow-hidden relative">
                  <img src={imgSrc} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-8 flex flex-col flex-grow">
                  <p class="text-xs text-stone-400 font-bold tracking-widest uppercase mb-3">{post.data.date}</p>
                  <h3 class="font-heading text-2xl font-bold text-stone-900 group-hover:text-terracotta transition-colors mb-3 line-clamp-2">{post.data.title}</h3>
                  <p class="text-stone-600 line-clamp-3 mb-6 flex-grow">{post.data.excerpt}</p>
                  <div class="inline-flex items-center text-terracotta font-bold text-sm uppercase tracking-wider group-hover:text-terracotta-dark transition-colors mt-auto">
                    {t.blog?.read_more || "Read more"}
                    <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-stone-500 text-lg">Content coming soon...</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
