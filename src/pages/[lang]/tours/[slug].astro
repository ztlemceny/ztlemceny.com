---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '../../../utils/i18n';
import { SITE, PRICING } from '../../../config';

export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return tours.map(tour => {
    const [slug] = tour.slug.split('.');
    return {
      params: { 
        lang: tour.data.lang,
        slug: slug
      },
      props: { tour },
    };
  });
}

const { tour } = Astro.props;
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const { title, tagline, duration, difficulty, images, included, not_included, price, extra_person_fee, itinerary } = tour.data;
const { Content } = await tour.render();

const mainImage = images[0] ?? '/images/shots/shot-01.jpg';

const whatsappMessage = t.tours.whatsapp_message_template
  .replace('{title}', title)
  .replace('{price}', price || t.tours.price_value);
const whatsappUrl = `${SITE.whatsappUrl}?text=${encodeURIComponent(whatsappMessage)}`;

// Get other tours for recommendations
const allTours = await getCollection('tours', ({ data }) => data.lang === lang);
const otherTours = allTours
  .filter(item => item.id !== tour.id)
  .sort(() => 0.5 - Math.random())
  .slice(0, 3);

// Schema.org JSON-LD
const schema = {
  "@context": "https://schema.org",
  "@type": "Trip",
  "name": title,
  "description": tagline,
  "image": mainImage,
  "provider": {
    "@type": "Person",
    "name": "Hamza",
    "jobTitle": "Licensed Tour Guide"
  },
  "offers": {
    "@type": "Offer",
    "price": price?.replace(/[^0-9]/g, '') || "90",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock"
  },
  "itinerary": itinerary?.map((step, index) => ({
    "@type": "ItemList",
    "name": `Stop ${index + 1}`,
    "description": step
  }))
};
---

<BaseLayout title={title} lang={lang} image={mainImage} description={tagline}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <!-- Hero / Header Image -->
  <section class="relative h-[60vh] min-h-[400px] overflow-hidden">
    <div class="absolute inset-0 watermark">
      <img src={mainImage.startsWith('/') ? `${import.meta.env.BASE_URL}${mainImage}`.replace(/\/+/g, '/') : mainImage} alt={title} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-stone-900/40"></div>
    </div>
    <div class="relative h-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-end pb-12">
      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-terracotta text-white text-xs font-bold rounded-full mb-4 uppercase tracking-widest">
          {duration} • {difficulty}
        </span>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-4 drop-shadow-lg">{title}</h1>
        <p class="text-xl text-stone-100 font-medium italic drop-shadow-md">{tagline}</p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <!-- Left: Description & Itinerary -->
        <div class="lg:col-span-2 space-y-12">
          
          <!-- Body text -->
          <div class="prose prose-stone prose-lg max-w-none">
            <Content />
          </div>

          <!-- Itinerary -->
          {itinerary && (
            <div class="bg-sand-50 rounded-3xl p-8 md:p-10 border border-sand-200 reveal">
              <h2 class="font-heading text-2xl font-bold text-stone-900 mb-8 flex items-center gap-3">
                <svg class="w-7 h-7 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A2 2 0 013 15.488V5.512a2 2 0 011.553-1.944L10 1.223a2 2 0 011.447 0l5.447 2.724A2 2 0 0118 5.877v9.976a2 2 0 01-1.553 1.944L10 21.777a2 2 0 01-1.447 0z" />
                </svg>
                {t.tours.itinerary_label}
              </h2>
              <div class="relative ps-6 border-s-2 border-terracotta/20 space-y-8">
                {itinerary.map((step) => (
                  <div class="relative">
                    <div class="absolute -start-[2.15rem] top-1.5 w-4 h-4 rounded-full bg-terracotta border-4 border-white shadow-sm"></div>
                    <p class="text-lg text-stone-700 leading-relaxed font-medium">{step}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Photo gallery for this tour -->
          {images.length > 1 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 reveal">
              {images.slice(1).map((img) => (
                <div 
                  class="rounded-2xl overflow-hidden aspect-video watermark gallery-item cursor-pointer group"
                  data-src={img.startsWith('/') ? `${import.meta.env.BASE_URL}${img}`.replace(/\/+/g, '/') : img}
                  data-caption={title}
                >
                  <img src={img.startsWith('/') ? `${import.meta.env.BASE_URL}${img}`.replace(/\/+/g, '/') : img} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
              ))}
            </div>
          )}

          <!-- Tour FAQs -->
          {t.tours.faqs && t.tours.faqs.length > 0 && (
            <div class="pt-8">
              <h2 class="font-heading text-2xl font-bold text-stone-900 mb-6 flex items-center gap-3">
                <svg class="w-7 h-7 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {t.tours.faq_title}
              </h2>
              <div class="space-y-4">
                {t.tours.faqs.map((faq: { q: string, a: string }) => (
                  <details class="group bg-white rounded-2xl border border-stone-200 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                    <summary class="flex items-center justify-between p-6 cursor-pointer text-stone-900 font-bold hover:text-terracotta transition-colors">
                      {faq.q}
                      <span class="ml-4 flex-shrink-0 transition-transform duration-300 group-open:rotate-180">
                        <svg class="w-5 h-5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </span>
                    </summary>
                    <div class="px-6 pb-6 text-stone-600 leading-relaxed">
                      {faq.a}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Right: Sidebar Info & Booking -->
        <aside class="space-y-6">
          <div class="sticky top-24 space-y-6">
            
            <!-- Details Card -->
            <div class="bg-white rounded-3xl p-6 border border-stone-100 shadow-sm space-y-6 overflow-hidden relative">
              <!-- Premium Accent -->
              <div class="absolute top-0 right-0 w-32 h-32 bg-terracotta/5 rounded-full -mr-16 -mt-16 blur-2xl"></div>
              
              <div class="flex items-center justify-between mb-2 relative z-10">
                <div>
                  <p class="text-xs text-stone-400 uppercase tracking-widest mb-1">{t.tours.price_label}</p>
                  <div class="flex items-baseline gap-1">
                    <p id="dynamic-price" class="text-3xl font-bold text-stone-900 transition-all duration-300">{price || t.tours.price_value}</p>
                    <span class="text-stone-400 text-xs">{t.tours.per_group}</span>
                  </div>
                </div>
              </div>
              <p class="text-[11px] text-stone-400 italic mb-4 leading-tight">{t.tours.price_disclaimer}</p>

              <!-- Vehicle Indicator -->
              <div id="vehicle-indicator" class="flex items-center gap-3 p-3 bg-stone-50 rounded-2xl border border-stone-100 hidden">
                <div class="p-2 bg-white rounded-xl shadow-sm text-terracotta">
                  <svg id="vehicle-icon-sedan" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2a1 1 0 011-1h8z" />
                  </svg>
                  <svg id="vehicle-icon-van" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] text-stone-400 uppercase tracking-widest leading-none mb-1">{t.tours.vehicle_label}</p>
                  <p id="vehicle-name" class="text-sm font-bold text-stone-700 leading-none capitalize">{t.tours.vehicle_sedan}</p>
                </div>
              </div>

              <hr class="border-stone-100" />

              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-terracotta mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="text-xs text-stone-400 uppercase tracking-widest">{t.tours.duration_label}</p>
                    <p class="font-bold text-stone-700">{duration}</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-terracotta mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <div>
                    <p class="text-xs text-stone-400 uppercase tracking-widest">Difficulty</p>
                    <p class="font-bold text-stone-700">{difficulty}</p>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 gap-6 pt-4">
                <div>
                  <p class="font-bold text-stone-900 mb-3 text-sm">{t.tours.included_label}</p>
                  <ul class="space-y-2">
                    {included.map((item) => (
                      <li class="flex items-start gap-2 text-stone-600 text-sm">
                        <svg class="w-4 h-4 text-olive mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <p class="font-bold text-stone-900 mb-3 text-sm">{t.tours.not_included_label}</p>
                  <ul class="space-y-2">
                    {not_included.map((item) => (
                      <li class="flex items-start gap-2 text-stone-400 text-sm italic">
                        <svg class="w-4 h-4 text-stone-300 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <form id="booking-form" class="space-y-4 pt-4 border-t border-stone-100">
                <div class="space-y-1">
                  <label for="booking-date" class="block text-xs font-bold text-stone-700 uppercase tracking-widest">{t.tours.booking_date_label}</label>
                  <input 
                    type="date" 
                    id="booking-date" 
                    required 
                    min={new Date().toISOString().split('T')[0]} 
                    max="9999-12-31"
                    class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-xl focus:ring-2 focus:ring-terracotta/20 focus:border-terracotta outline-none transition-all text-stone-700" 
                  />
                </div>
                <div class="space-y-1">
                  <label for="booking-guests" class="block text-xs font-bold text-stone-700 uppercase tracking-widest">{t.tours.booking_guests_label}</label>
                  <select id="booking-guests" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-xl focus:ring-2 focus:ring-terracotta/20 focus:border-terracotta outline-none transition-all text-stone-700 appearance-none">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6+">6+</option>
                  </select>
                </div>
                
                <button
                  type="submit"
                  class="w-full flex items-center justify-center gap-2 py-4 bg-terracotta text-white font-bold rounded-2xl shadow-lg hover:bg-terracotta-dark transition-all transform hover:-translate-y-1 active:scale-95 mt-2"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  {t.tours.reserve_button}
                </button>
              </form>
            </div>

            <!-- Lonely Planet Badge -->
            <div class="bg-sand-50 rounded-3xl p-6 border border-sand-200 flex items-center gap-4 group hover:bg-white transition-all duration-500">
              <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-terracotta" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-9l6 4.5-6 4.5z"/>
                </svg>
              </div>
              <div>
                <p class="text-[10px] text-terracotta font-bold uppercase tracking-widest leading-none mb-1">{t.about.lp_label}</p>
                <p class="text-sm font-bold text-stone-800 leading-tight">{t.about.lp_value}</p>
              </div>
            </div>

            <!-- Help card -->
            <div class="bg-stone-900 rounded-3xl p-6 text-white relative overflow-hidden">
              <div class="absolute top-0 right-0 w-24 h-24 bg-terracotta/10 rounded-full -mr-12 -mt-12 blur-xl"></div>
              <h3 class="font-heading text-lg font-bold mb-2 relative z-10">Need Help?</h3>
              <p class="text-stone-400 text-sm mb-4 leading-relaxed relative z-10">
                Have questions about this tour or want to customize your experience? Contact me directly.
              </p>
              <a href={`mailto:${SITE.email}`} class="text-terracotta font-bold hover:underline relative z-10">
                {SITE.email}
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Mobile Sticky Booking Bar -->
  <div id="mobile-booking-bar" class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-stone-100 p-4 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] flex items-center justify-between lg:hidden translate-y-full transition-transform duration-500">
    <div>
      <p class="text-[10px] text-stone-400 uppercase tracking-widest leading-none mb-1">{t.tours.price_label}</p>
      <p id="mobile-price-display" class="text-xl font-bold text-stone-900 leading-none">{price || t.tours.price_value}</p>
    </div>
    <button id="mobile-reserve-btn" class="bg-terracotta text-white px-6 py-3 rounded-xl font-bold text-sm shadow-md active:scale-95 transition-all">
      {t.nav.reserve}
    </button>
  </div>

  <!-- Other Tours -->
  <section class="py-20 bg-sand-50 border-t border-sand-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-stone-900 mb-10 text-center">Other Experiences</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {otherTours.map((item) => {
           const [s] = item.slug.split('.');
           const link = `${import.meta.env.BASE_URL}/${lang}/tours/${s}`.replace(/\/+/g, '/');
           const tourImage = item.data.images[0];
           const tourImgSrc = tourImage.startsWith('/') ? `${import.meta.env.BASE_URL}${tourImage}`.replace(/\/+/g, '/') : tourImage;
           return (
            <a href={link} class="group bg-white rounded-3xl overflow-hidden shadow-sm border border-stone-100 hover:shadow-md transition-all">
              <div class="aspect-video watermark overflow-hidden">
                <img src={tourImgSrc} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-6">
                <h3 class="font-bold text-stone-900 group-hover:text-terracotta transition-colors line-clamp-1">{item.data.title}</h3>
                <p class="text-stone-500 text-sm mt-1">{item.data.duration}</p>
              </div>
            </a>
           );
        })}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[60] bg-black/90 hidden items-center justify-center p-4">
    <button id="lightbox-close" class="absolute top-4 end-4 text-white/70 hover:text-white transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="watermark">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl" />
    </div>
    <p id="lightbox-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/80 text-sm text-center"></p>
  </div>

</BaseLayout>

<script define:vars={{ 
  whatsappBaseUrl: SITE.whatsappUrl, 
  title: title, 
  basePriceStr: price || t.tours.price_value, 
  extraPersonFee: extra_person_fee,
  pricingTiers: PRICING.tiers,
  messageTemplate: t.tours.booking_whatsapp_message,
  labels: {
    sedan: t.tours.vehicle_sedan,
    van: t.tours.vehicle_van,
    minibus: t.tours.vehicle_minibus
  }
}}>
  function initBooking() {
    const form = document.getElementById('booking-form');
    if (!form) return;
    
    const guestsInput = document.getElementById('booking-guests');
    const priceDisplay = document.getElementById('dynamic-price');
    const vehicleIndicator = document.getElementById('vehicle-indicator');
    const vehicleName = document.getElementById('vehicle-name');
    const iconSedan = document.getElementById('vehicle-icon-sedan');
    const iconVan = document.getElementById('vehicle-icon-van');

    // Mobile Sticky Bar Logic
    const mobileBar = document.getElementById('mobile-booking-bar');
    const mobilePriceDisplay = document.getElementById('mobile-price-display');
    const mobileReserveBtn = document.getElementById('mobile-reserve-btn');
    
    const handleScroll = () => {
      if (!mobileBar) return;
      // Show after scrolling past hero
      if (window.scrollY > 400) {
        mobileBar.classList.remove('translate-y-full');
      } else {
        mobileBar.classList.add('translate-y-full');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    mobileReserveBtn?.addEventListener('click', () => {
      const formTop = form.getBoundingClientRect().top + window.scrollY - 100;
      window.scrollTo({ top: formTop, behavior: 'smooth' });
    });

    const updatePrice = () => {
      if (!guestsInput || !priceDisplay) return;
      const count = guestsInput.value === '6+' ? 7 : parseInt(guestsInput.value);
      const baseNum = parseInt(basePriceStr.replace(/[^0-9]/g, '')) || 0;
      
      let total = baseNum;
      let vehicle = 'sedan';
      
      if (extraPersonFee !== undefined && extraPersonFee !== null) {
        // Linear pricing: base + (n-1)*extra
        total = baseNum + (count - 1) * extraPersonFee;
        
        // Determine vehicle based on count
        if (count <= pricingTiers.base.maxGuests) vehicle = pricingTiers.base.vehicle;
        else if (count <= pricingTiers.small.maxGuests) vehicle = pricingTiers.small.vehicle;
        else if (count <= pricingTiers.van.maxGuests) vehicle = pricingTiers.van.vehicle;
        else vehicle = pricingTiers.large.vehicle;
      } else {
        // Tiered pricing logic
        let extra = 0;
        if (count <= pricingTiers.base.maxGuests) {
          extra = pricingTiers.base.extra;
          vehicle = pricingTiers.base.vehicle;
        } else if (count <= pricingTiers.small.maxGuests) {
          extra = pricingTiers.small.extra;
          vehicle = pricingTiers.small.vehicle;
        } else if (count <= pricingTiers.van.maxGuests) {
          extra = pricingTiers.van.extra;
          vehicle = pricingTiers.van.vehicle;
        } else {
          extra = pricingTiers.large.extra;
          vehicle = pricingTiers.large.vehicle;
        }
        total = baseNum + extra;
      }

      const formattedPrice = basePriceStr.includes('€') ? `${total} €` : `${total}`;
      
      priceDisplay.textContent = formattedPrice;
      if (mobilePriceDisplay) mobilePriceDisplay.textContent = formattedPrice;
      
      // Update vehicle
      if (vehicleIndicator && vehicleName) {
        vehicleIndicator.classList.remove('hidden');
        vehicleName.textContent = labels[vehicle] || vehicle;
        
        if (iconSedan && iconVan) {
          if (vehicle === 'sedan') {
            iconSedan.classList.remove('hidden');
            iconVan.classList.add('hidden');
          } else {
            iconSedan.classList.add('hidden');
            iconVan.classList.remove('hidden');
          }
        }
      }
    };

    guestsInput?.addEventListener('change', updatePrice);
    updatePrice();

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      try {
        const dateInput = document.getElementById('booking-date');
        const date = dateInput ? dateInput.value : '';
        const guests = guestsInput ? guestsInput.value : '1';
        const currentPrice = priceDisplay ? priceDisplay.textContent : basePriceStr;
        
        if (!date) {
          alert('Please select a date');
          return;
        }

        const message = messageTemplate
          .replace('{title}', title)
          .replace('{price}', currentPrice)
          .replace('{date}', date)
          .replace('{guests}', guests);
          
        const url = `${whatsappBaseUrl}?text=${encodeURIComponent(message)}`;
        window.open(url, '_blank', 'noopener,noreferrer');
      } catch (err) {
        console.error('Booking error:', err);
      }
    });

    // Lightbox logic
    const items = document.querySelectorAll('.gallery-item');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const lightboxClose = document.getElementById('lightbox-close');

    items.forEach(item => {
      item.addEventListener('click', () => {
        if (!lightbox || !lightboxImg || !lightboxCaption) return;
        lightboxImg.src = item.dataset.src;
        lightboxCaption.textContent = item.dataset.caption;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    const closeLightbox = () => {
      if (!lightbox) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
      if (lightboxImg) lightboxImg.src = '';
    };

    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', e => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeLightbox();
    });
  }

  // Run on initial load
  initBooking();
  // Also run on Astro page load (for view transitions support if enabled later)
  document.addEventListener('astro:page-load', initBooking);
</script>
